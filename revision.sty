\long\def\Removed#1{\Deleted{#1}}
\long\def\Replaced#1#2{\Deleted{#1}\Modified{#2}}

% Extracts section name (e.g., "Section 1.1")
% @see https://tex.stackexchange.com/questions/141367/how-can-i-reference-the-current-subsection-number
\def\rev@SectionName{%
  \ifnum\c@section=0%
    Abstract%
  \else\ifnum\c@subsection=0%
    Section~\thesection%
  \else\ifnum\c@subsubsection=0%
    Section~\thesubsection%
  \else%
    Section~\thesubsubsection%
  \fi\fi\fi%
}

%-------------------------------------------------------------------

% 1. \rev@WriteRevision{<rid>}{<content>} in paper.tex
%   - Writes to paper.aux the location as '\newlabel{revised:<rid>}{{<section-info>}{<page-number>}}'
%   - Writes to paper.aux the content  as '\newlabel{content:<rid>}{{-}{<content>}}'
\long\def\rev@WriteRevision#1#2{%
  \immediate\write\@auxout{\string\newlabel{revised:#1}{{\rev@SectionName}{\thepage}}}%
  \Copy{#1}{#2}
}

% 2. \rev@WriteReference{<rid>}{<cid>} in letter.tex
%   - Aggregates the list of revision IDs at \rev@comment@<rid>
%   - Writes to letter.aux the relationship as '\newlabel{comment:<rid>}{{<cid>...}{<length>}}'
\def\rev@WriteReference#1#2{%
  % accumerates comment IDs for the target revision at \rev@comment@<rid>
  % \edef\rev@comment@revised:<rid>{<cid>,<cid>}
  \ifcsname rev@comment@#1\endcsname%
    \edef\rev@tmp{\csname rev@comment@#1\endcsname}%
    \g@addto@macro\rev@tmp{,#2}%
  \else%
    \edef\rev@tmp{#2}%
  \fi%
  \expandafter\edef\csname rev@comment@#1\endcsname{\rev@tmp}%
  %
  % Writes the list of comment IDs,
  % but skips to write it if its string length is shorter then the previous
  \StrLen{\rev@tmp}[\rev@tmplen]%
  \setrefcountdefault{-1}%
  \ifnum\getpagerefnumber{comment:#1}>\rev@tmplen%
    \relax%
  \else%
    \immediate\write\@auxout{\string\newlabel{comment:#1}{{\rev@tmp}{\rev@tmplen}}}%
  \fi
}

% 3. \rev@CommentIdContent{<rid>} in paper.tex
%   - Splits the contents of \rev@ref{<rid>}
%   - Writes to letter.aux the relationship as '\newlabel{comment:<rid>}{{<cid>...}{<length>}}'
\def\rev@CommentIdContent#1{%
  \edef\rev@tmp{\rev@ref{comment:#1}}%
  \begin{minipage}{0.1cm}%
  \rev@CommentIdContentImpl{\rev@tmp}%
  \end{minipage}
}
\def\rev@CommentIdContentImpl#1{%
  \IfSubStr{#1}{,}{% multiple
    \saveexpandmode\expandarg%
      \StrBefore{#1}{,}[\rev@tmpbefore]%
      \StrBehind{#1}{,}[\rev@tmpbehind]%
    \restoreexpandmode%
    \rev@CommentIdBox{\rev@tmpbefore}\\%
    \rev@CommentIdContentImpl{\rev@tmpbehind}%
  }{% single
    \rev@CommentIdBox{#1}%
  }%
}

% Alternatives of \setref, \ref, and \pageref using the namespace r@
% @see https://oku.edu.mie-u.ac.jp/~okumura/texfaq/qa/14602.html
\def\rev@setref#1#2{\ifx#1\relax X\else\expandafter#2#1\fi}
\def\rev@ref#1{\expandafter\rev@setref\csname r@#1\endcsname\rev@fst}
\def\rev@pageref#1{\expandafter\rev@setref\csname r@#1\endcsname\rev@snd}
\long\def\rev@fst#1#2{#1}
\long\def\rev@snd#1#2{#2}

% floating comment

\def\RRef#1{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#1}{\rev@ReferenceId}%
  \rev@CommentIdBox{\rev@ReferenceId}%
}
\def\RTouch#1{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#1}{\rev@ReferenceId}%
}
\def\RQuote#1{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#1}{\rev@ReferenceId}%
  \begin{Quote}{\rev@CommentIdBox{\rev@ReferenceId} [\ref{revised:#1}, Page~\pageref{revised:#1}]}%
    \Paste{#1}%
  \end{Quote}%
}
\def\CopyQuotation#1{\RQuote{#1}}

% copy-and-paste feature
\long\def\RCopy#1#2{%
  \expandafter\def\csname rev@clipboard@#1\endcsname{#2}%
  #2%
}
\def\RPaste#1{\csname rev@clipboard@#1\endcsname}



%%% Comment and Reply feature

% comment/reference counter
\newcounter{RevComment}
\setcounter{RevComment}{0}
\newcounter{RevReference}
\setcounter{RevReference}{0}

% reviewer id
\xdef\rev@ReviewerId{0}
\def\Reviewer#1{%
  \xdef\rev@ReviewerId{#1}%
  \setcounter{RevComment}{0}%
}

% comment id
\def\rev@CommentId{}
\def\rev@GenerateCommentId#1{
  \ifx*#1% default
    \addtocounter{RevComment}{1}%
    \xdef\rev@CommentId{\rev@ReviewerId.\arabic{RevComment}}
  \else%
    \xdef\rev@CommentId{\rev@ReviewerId.#1}
  \fi%
  \setcounter{RevReference}{0}%
}

% reference id
\def\rev@ReferenceId{}
\def\rev@GenerateReferenceId{
  \addtocounter{RevReference}{1}%
  \xdef\rev@ReferenceId{\rev@CommentId\alphalph{\value{RevReference}}}
}

% comment
\newcommand{\Comment}[1][*]{%
  % id generation
  \rev@GenerateCommentId{#1}%
  % hr
  \rev@HorizontalLine
  \vspace{0em}
  
  \noindent
  \rev@CommentBox{gray}{\rev@CommentSymbol\rev@CommentId}\xspace%
  \begingroup
  \itshape % start italic
  \small
  \color{gray}
}
\newcommand{\Reply}{%
  \endgroup % end italic
  ~ \\
  \rev@CommentBox{black}{\rev@AnswerSymbol\rev@CommentId}\xspace%
}

% quote
\newenvironment{Quote}[1]%
  {\vspace{1em}\small\begin{quote}#1\\}%
  {\end{quote}}

% author note
\def\Note#1#2{{\footnotesize\begin{quote}[** #1] #2\end{quote}}}

\DeclareOption{paper}{%
  \def\Label#1{\rev@MarginPar{\rev@CommentIdContent{#1}}}
  \long\def\Revised#1#2{%
    \Label{#1}%
    \rev@WriteRevision{#1}{#2}%
    %{#2}%
  }
  \long\def\RevisedNoMark#1#2{{#2}\rev@WriteRevision{#1}{#2}}
  \long\def\Modified#1{\rev@HighlightedText{#1}}
  \long\def\Deleted#1{\rev@StrikedText{#1}}
}
\DeclareOption{cameraready}{%
  \def\Label#1{}
  \long\def\Revised#1#2{#2}
  \long\def\RevisedNoMark#1#2{#2}
  \long\def\Modified#1{#1}
  \long\def\Deleted#1{}
}
\DeclareOption{letter}{%
  \long\def\Revised#1#2{#2}
  \long\def\Modified#1{\rev@HighlightedText{#1}}
  \long\def\Removed#1{\rev@StrikedText{#1}}
}

