% cross-referencing
% https://www.overleaf.com/learn/how-to/Cross_referencing_with_the_xr_package_in_Overleaf
\newcommand*{\rev@AddFileDependency}[1]{%
  \typeout{(#1)}%
  \@addtofilelist{#1}%
  \IfFileExists{#1}{}{\typeout{No file #1.}}%
}
\newcommand*{\myexternaldocument}[1]{%
  \externaldocument{#1}%
  \rev@AddFileDependency{#1.tex}%
  \rev@AddFileDependency{#1.aux}%
}

% basic literal definition
\gdef\rev@CommentSymbol{Comment }
\gdef\rev@AnswerSymbol{Answer to }

% basic style definition
\long\def\rev@HighlightedText#1{{\color{blue}#1}}
\long\def\rev@StrikedText#1{{\color{red}\sout{#1}}}
\def\rev@HorizontalLine{\noindent\textcolor{lightgray}{\rule{\linewidth}{1pt}}}
\def\rev@CommentBox#1#2{\colorbox{#1}{{\color{white}\textbf{#2}}}}
\def\rev@TableBox#1#2{{\tabcolsep=1.5pt\renewcommand{\arraystretch}{0.8}\begin{tabular}{|>{\columncolor{#1}}l|}\hline#2\\\hline\end{tabular}}}
\def\rev@CommentIdBox#1{%
  \StrChar{#1}{1}[\rev@tmpreviewerid]%
  {\begingroup%
    \small%
    \bfseries%
    \color{black}%
    \colorlet{cv}{Reviewer\rev@tmpreviewerid}%
    \rev@TableBox{cv}{#1}%
  \endgroup}%
}
