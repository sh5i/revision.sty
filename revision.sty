% -*- latex -*-
\NeedsTeXFormat{pLaTeX2e}[2001/09/04]
\ProvidesPackage{revision}[2010/09/16, hayashi]

% usage:
% \usepackage[paper]{revision},
% \usepackage[cr]{revision}, or
% \usepackage[letter]{revision}

\DeclareOption{en}{%
  \gdef\r@SecNameGen#1{Section~#1}
  \gdef\r@AbstractName{Abstract}
  \gdef\r@CommentName{Comment~}
  \gdef\r@ConditionName{Condition~}
}
\DeclareOption{ja}{%
  \gdef\r@SecNameGen#1{{#1}節}
  \gdef\r@AbstractName{概要}
  \gdef\r@CommentName{コメント}
  \gdef\r@ConditionName{採録条件}
}

\DeclareOption{paper}{%
  \AtEndOfPackage{
    \RequirePackage{color}
    \RequirePackage{xr}
    \RequirePackage{xstring}
    %\RequirePackage[normalem]{ulem}
    \RequirePackage{udline}
  }
  \def\IfRevision#1{#1}

  \def\Modified#1{{\color{red}#1}}
  \def\M#1{\Modified{#1}}
  \def\Mod#1{\Modified{#1}}

  \def\Added#1{\Modified{#1}}
  \def\Add#1{\Modified{#1}}
  %\def\Removed#1{}
%  \def\Deleted#1{\Modified{\sout{#1}}}
  \def\Deleted#1{\Modified{\Sl{#1}}}
  \def\Del#1{\Deleted{#1}}
  \def\D#1{\Deleted{#1}}
  \def\Replaced#1#2{\Deleted{#1}\Modified{#2}}
  \def\Rep#1#2{\Replaced{#1}{#2}}

  %\def\revB#1{{\color{blue}#1}}
  %\def\rev#1{{\color[named]{Purple}#1}}
  %\def\revC#1{{\color[named]{OliveGreen}#1}}

  % extracting section number
  % BUGGY??
  \def\r@SecNumber{%
    \ifnum\c@section>0%
      \ifnum\c@subsection>0%
        \ifnum\c@subsubsection>0%
          \thesubsubsection%
        \else%
          \thesubsection%
        \fi%
      \else%
        \thesection%
      \fi%
    \else%
      %
    \fi%
  }

  % section name (Section 1.1, etc.)
  \def\r@SecName{%
    \ifnum\c@section>0%
      \ifnum\c@subsection>0%
        \ifnum\c@subsubsection>0%
          \r@SecNameGen{\thesubsubsection}%
        \else%
          \r@SecNameGen{\thesubsection}%
        \fi%
      \else%
        \r@SecNameGen{\thesection}%
      \fi%
    \else%
      \r@AbstractName%
    \fi%
  }

  % floating comment
  \def\r@marginparL#1{\marginpar{\begin{flushright}#1\end{flushright}}}
  \def\r@marginparR#1{\marginpar{#1}}
  \def\r@marginparLR#1{\if@firstcolumn\r@marginparR{#1}\else\r@marginparR{#1}\fi}
  \def\r@marginparBoth#1{\marginpar{%
    \begin{minipage}{0.495\hsize}\begin{flushleft}#1\end{flushleft}\end{minipage}%
    \begin{minipage}{0.495\hsize}\begin{flushright}#1\end{flushright}\end{minipage}%
  }}
  \def\CommentIdContent#1{%
    \edef\r@tmp{\@ifundefined{r@#1}{?}{\ref{#1}}}%
    \saveexpandmode\expandarg%
      \StrSubstitute\r@tmp,{\noexpand\\}[\r@tmp]%
    \restoreexpandmode%
    {\small\bf\color{red}\tabcolsep=1.5pt\renewcommand{\arraystretch}{0.8}%
      \begin{tabular}{|l|}%
        \hline
        \r@tmp \\\hline%
      \end{tabular}}%
  }
%  \def\ShowCommentId#1{\r@marginparBoth{\CommentIdContent{comment:#1}}}
  \def\ShowCommentId#1{\r@marginparR{\CommentIdContent{comment:#1}}}

  \long\def\WriteRevision#1#2#3{%
    \@temptokena{#3}%
    \immediate\write\@auxout{\string\newlabel{#1}{{#2}{\thepage}}}%
    \immediate\write\@auxout{\string\newlabel{content:#1}{{#2}{\the\@temptokena}}}
  }
  \long\def\Revised#1#2{% #1:key, #2:contents
    \WriteRevision{revised:#1}{\r@SecName}{#2}%
    \ShowCommentId{#1}%
    {#2}%
  }
  \long\def\Rev#1#2{\Revised{#1}{#2}}
  \long\def\R#1#2{\Revised{#1}{#2}}
}

\DeclareOption{cameraready}{%
  \def\IfRevision#1{}
  \long\def\Revised#1#2{#2}
  \def\Modified#1{#1}
  \def\Deleted#1{}
}

\DeclareOption{letter}{%
  \AtEndOfPackage{
    \RequirePackage{color}
    \RequirePackage{okumacro}
    \RequirePackage{xr}
    \RequirePackage{ifmtarg}
    \RequirePackage{xstring}
    \RequirePackage{refcount}
    \RequirePackage[normalem]{ulem}

    % http://newsgroups.derkeiler.com/Archive/Comp/comp.text.tex/2009-05/msg00262.html
    % \cite on xr
    \long\def\XR@test#1#2#3#4\XR@{%
      \ifx#1\newlabel
        \newlabel{\XR@prefix#2}{#3}%
      \else%
        \ifx#1\@input
          \edef\XR@list{\XR@list#2\relax}%
        \fi%
      \fi
      \ifx\bibcite#1\relax
        \bibcite{\XR@prefix#2}{#3}%
      \fi
      \ifeof\@inputcheck\expandafter\XR@aux
      \else\expandafter\XR@read\fi%
    }
  }

  \long\def\Revised#1#2{#2}
  \long\def\Modified#1{{\color{red}#1}}
  \long\def\Removed#1{\Modified{\sout{#1}}}

  % comment counter
  \xdef\r@CommentCounter{}
  \newcounter{comment}
  \setcounter{comment}{0}

  % reviewer id
  \xdef\r@ReviewerId{0}
  \def\Reviewer#1{%
    \xdef\r@ReviewerId{#1}%
    \setcounter{comment}{0}%
    \clearpage%
  }

  % comment id
  \def\r@CommentId{}
  \def\r@GenerateCommentId#1{
    \addtocounter{comment}{1}%
    \ifx-#1%
      \xdef\r@CommentId{\r@ReviewerId-\arabic{comment}}
    \else%
      \xdef\r@CommentId{\r@ReviewerId-#1}
    \fi%
  }
  \def\r@Caption#1{\@ifmtarg{#1}{}{~[#1]}}
  
  % comment
  \newenvironment{Comment}[2][-]%
    {\r@GenerateCommentId{#1}%
     \small%
     \begin{screen}%
     \textbf{\r@CommentName\r@CommentId\r@Caption{#2}:~}}%
    {\end{screen}}
  % \Alph{com} : A, B, C...

  % condition
  \newenvironment{Condition}[2][-]%
    {\r@GenerateCommentId{#1}%
     \small%
     \begin{screen}%
     \textbf{\r@ConditionName\r@CommentId\r@Caption{#2}:~}}%
    {\end{screen}}
  % \Alph{com} : A, B, C...

  \def\Caption#1{\textbf{[#1]}~}

  \newenvironment{Quote}[1]%
    {\vspace{1em}\small\begin{quote} [#1]\\}%
    {\end{quote}}

  \def\r@WriteReference#1#2{% #1:id, #2: content
    \ifcsname r@comment@#1\endcsname%
      \edef\r@tmp{\csname r@comment@#1\endcsname}%
      \g@addto@macro\r@tmp{,#2}%
    \else%
      \edef\r@tmp{#2}%
    \fi%
    \expandafter\edef\csname r@comment@#1\endcsname{\r@tmp}%
    \StrLen{\r@tmp}[\r@tmplen]%
    %
    % Skip to write if its size is shorter then previous
    %    \ifnum\StrLen{\r@tmp}<\StrLen{\pageref{#1}}%
    \setrefcountdefault{-1}%
    \ifnum\getpagerefnumber{#1}>\r@tmplen%
      \relax%
    \else%
      \immediate\write\@auxout{\string\newlabel{#1}{{\r@tmp}{\r@tmplen}}}%
    \fi
  }
  \def\CopyQuotation#1{%
    % write relationship
    \r@WriteReference{comment:#1}{\r@CommentId}%
    \begin{Quote}{p.~\pageref{revised:#1}, \ref{content:revised:#1}}%
      \pageref{content:revised:#1}%
    \end{Quote}%
  }

  % copy-and-paste feature
  \long\def\Copy#1#2{%
    \expandafter\def\csname r@clipboard@#1\endcsname{#2}%
    #2%
  }
  \def\Paste#1{\csname r@clipboard@#1\endcsname}

  \def\Note#1#2{%
    {\footnotesize \begin{quote}%
      [★ #1] #2
    \end{quote}}%
  }
}

\ExecuteOptions{paper}
\ProcessOptions
