  \ifrev@ja\RequirePackage{uline--}\else\RequirePackage[normalem]{ulem}\fi
  \RequirePackage{refcount}
  \RequirePackage{xspace}
  \RequirePackage{alphalph}
  \RequirePackage{marginnote}
  \RequirePackage{clipboard}
  \definecolor{Reviewer0}{rgb}{0.8,1.0,1.0}
  \definecolor{ReviewerM}{rgb}{0.8,1.0,1.0}
  \definecolor{Reviewer1}{rgb}{0.8,1.0,0.8}
  \definecolor{ReviewerA}{rgb}{0.8,1.0,0.8}
  \definecolor{Reviewer2}{rgb}{1.0,0.8,1.0}
  \definecolor{ReviewerB}{rgb}{1.0,0.8,1.0}
  \definecolor{Reviewer3}{rgb}{1.0,1.0,0.8}
  \definecolor{ReviewerC}{rgb}{1.0,1.0,0.8}
  \definecolor{ReviewerX}{rgb}{0.7,0.7,0.7}
}

% cross-referencing
% https://www.overleaf.com/learn/how-to/Cross_referencing_with_the_xr_package_in_Overleaf
\newcommand*{\rev@AddFileDependency}[1]{%
  \typeout{(#1)}%
  \@addtofilelist{#1}%
  \IfFileExists{#1}{}{\typeout{No file #1.}}%
}
\newcommand*{\myexternaldocument}[1]{%
  \externaldocument{#1}%
  \rev@AddFileDependency{#1.tex}%
  \rev@AddFileDependency{#1.aux}%
}

% basic literal definition
% Each takes what it labels as its argument, so that a translation may
% put the word after the number (see the ja option).
\gdef\rev@CommentText#1{Comment #1}
\gdef\rev@AnswerText#1{Answer to #1}
\gdef\rev@PageText#1{Page~#1}
\gdef\rev@AbstractText{Abstract}
\gdef\rev@SectionText#1{Section~#1}

% basic style definition
\long\def\rev@HighlightedText#1{{\color{blue}#1}}
\long\def\rev@StrikedText#1{{\color{red}\sout{#1}}}
\def\rev@HorizontalLine{\noindent\textcolor{lightgray}{\rule{\linewidth}{1pt}}}
\def\rev@CommentBox#1#2{\colorbox{#1}{{\color{white}\textbf{#2}}}}
\def\rev@TableBox#1#2{{\tabcolsep=1.5pt\renewcommand{\arraystretch}{0.8}\begin{tabular}{|>{\columncolor{#1}}l|}\hline#2\\\hline\end{tabular}}}
\def\rev@CommentIdBox#1{%
  \StrChar{#1}{1}[\rev@tmpreviewerid]%
  {\begingroup%
    \small%
    \bfseries%
    \color{black}%
    % falls back to ReviewerX (gray) when Reviewer<id> is not defined,
    % e.g., for the fourth reviewer and beyond; warns once per id
    \@ifundefined{\string\color@Reviewer\rev@tmpreviewerid}{%
      \@ifundefined{rev@colorwarned@\rev@tmpreviewerid}{%
        \PackageWarning{revision}{Color 'Reviewer\rev@tmpreviewerid' is not
          defined; falling back to ReviewerX.  Define it with
          \string\definecolor{Reviewer\rev@tmpreviewerid}{rgb}{...}}%
        \expandafter\gdef\csname rev@colorwarned@\rev@tmpreviewerid\endcsname{}%
      }{}%
      \colorlet{cv}{ReviewerX}%
    }{%
      \colorlet{cv}{Reviewer\rev@tmpreviewerid}%
    }%
    \rev@TableBox{cv}{#1}%
  \endgroup}%
}
%\def\rev@CommentIdBox#1{\fcolorbox{black}{Reviewer0}{#1}}

\def\rev@MarginPar#1{\leavevmode%
%  \begingroup%
%  \ifodd\value{page}
%    \if@firstcolumn\reversemarginpar\fi
%  \else
%    \if@firstcolumn\else\reversemarginpar\fi
%  \fi
  \marginnote{#1~~~~~~~~~}%
%  \endgroup%
}
\setlength{\marginparwidth}{2cm}
\setlength{\marginparsep}{1mm}

% aliases
\long\def\R#1#2{\Revised{#1}{#2}}
\long\def\A#1{\Added{#1}}
\long\def\M#1{\Modified{#1}}
\long\def\D#1{\Deleted{#1}}
\long\def\RM#1#2{\Revised{#1}{\Modified{#2}}}
\long\def\Rep#1#2{\Replaced{#1}{#2}}
\long\def\Added#1{\Modified{#1}}
\long\def\Removed#1{\Deleted{#1}}
\long\def\Replaced#1#2{\Deleted{#1}\Modified{#2}}

% Extracts section name (e.g., "Section 1.1")
% @see https://tex.stackexchange.com/questions/141367/how-can-i-reference-the-current-subsection-number
% \relax terminates each number: without it TeX scans on for more digits
% and expands the following text, which swallows \thesection whenever the
% translation starts with the number rather than with a word.
\def\rev@SectionName{%
  \ifnum\c@section=0\relax
    \rev@AbstractText%
  \else\ifnum\c@subsection=0\relax
    \rev@SectionText{\thesection}%
  \else\ifnum\c@subsubsection=0\relax
    \rev@SectionText{\thesubsection}%
  \else%
    \rev@SectionText{\thesubsubsection}%
  \fi\fi\fi%
}

%-------------------------------------------------------------------

% 1. \rev@WriteRevision{<rid>}{<content>} in paper.tex
%   - Writes to paper.aux the location as '\newlabel{revised:<rid>}{{<section-info>}{<page-number>}}'
%   - Stores <content> in the clipboard for \RQuote
%   - Typesets <content>, since \Copy does: callers must not typeset it again
\long\def\rev@WriteRevision#1#2{%
  % \protected@write defers the \write to shipout so that \thepage is
  % correct even when the paragraph is moved to the following page
  % (\immediate\write expands \thepage too early).
  \protected@write\@auxout{}{\string\newlabel{revised:#1}{{\rev@SectionName}{\thepage}}}%
  \Copy{#1}{#2}%
}

% 2. \rev@WriteReference{<rid>}{<cid>} in letter.tex
%   - Aggregates the list of revision IDs at \rev@comment@<rid>
%   - Writes to letter.aux the relationship as '\newlabel{comment:<rid>}{{<cid>...}{<length>}}'
\def\rev@WriteReference#1#2{%
  % accumulates comment IDs for the target revision at \rev@comment@<rid>
  % \xdef\rev@comment@<rid>{<cid>,<cid>}
  % (globally, so that accumulation survives \RRef etc. used inside a group)
  \ifcsname rev@comment@#1\endcsname%
    \expandafter\xdef\csname rev@comment@#1\endcsname{\csname rev@comment@#1\endcsname,#2}%
  \else%
    \expandafter\xdef\csname rev@comment@#1\endcsname{#2}%
  \fi%
  \edef\rev@tmp{\csname rev@comment@#1\endcsname}%
  %
  % Writes the list of comment IDs,
  % but skips to write it if its string length is shorter than the previous
  \StrLen{\rev@tmp}[\rev@tmplen]%
  \setrefcountdefault{-1}%
  \ifnum\getpagerefnumber{comment:#1}>\rev@tmplen%
    \relax%
  \else%
    \immediate\write\@auxout{\string\newlabel{comment:#1}{{\rev@tmp}{\rev@tmplen}}}%
  \fi%
}

% 3. \rev@CommentIdContent{<rid>} in paper.tex
%   - Splits the contents of \rev@ref{<rid>}
%   - Writes to letter.aux the relationship as '\newlabel{comment:<rid>}{{<cid>...}{<length>}}'
\def\rev@CommentIdContent#1{%
  \edef\rev@tmp{\rev@ref{comment:#1}}%
  \begin{minipage}{0.1cm}%
  \rev@CommentIdContentImpl{\rev@tmp}%
  \end{minipage}
}
\def\rev@CommentIdContentImpl#1{%
  \IfSubStr{#1}{,}{% multiple
    \saveexpandmode\expandarg%
      \StrBefore{#1}{,}[\rev@tmpbefore]%
      \StrBehind{#1}{,}[\rev@tmpbehind]%
    \restoreexpandmode%
    \rev@CommentIdBox{\rev@tmpbefore}\\%
    \rev@CommentIdContentImpl{\rev@tmpbehind}%
  }{% single
    \rev@CommentIdBox{#1}%
  }%
}

% Alternatives of \setref, \ref, and \pageref using the namespace r@
% @see https://oku.edu.mie-u.ac.jp/~okumura/texfaq/qa/14602.html
% Labels imported by xr carry five fields ({ref}{page}{}{}{url});
% locally written ones carry two.  The trailing \rev@nil-delimited
% argument absorbs whatever follows the first two fields in either case.
\def\rev@setref#1#2{\ifx#1\relax X\else\expandafter#2#1\rev@nil\fi}
\def\rev@ref#1{\expandafter\rev@setref\csname r@#1\endcsname\rev@fst}
\def\rev@pageref#1{\expandafter\rev@setref\csname r@#1\endcsname\rev@snd}
\long\def\rev@fst#1#2#3\rev@nil{#1}
\long\def\rev@snd#1#2#3\rev@nil{#2}

% floating comment

% Location of a revision, e.g. 'Section 2, Page 3'
\def\rev@LocationText#1{\ref{revised:#1}, \rev@PageText{\pageref{revised:#1}}}

% \RRef[full]{<rid>} appends the location to the reference id
\newcommand{\RRef}[2][]{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#2}{\rev@ReferenceId}%
  \rev@CommentIdBox{\rev@ReferenceId}%
  \IfStrEq{#1}{}{}{%
    \IfStrEq{#1}{full}{~(\rev@LocationText{#2})}{%
      \PackageWarning{revision}{Unknown option '#1' for \string\RRef; ignored}%
    }%
  }%
}
\def\RTouch#1{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#1}{\rev@ReferenceId}%
}
\def\RQuote#1{%
  \rev@GenerateReferenceId%
  \rev@WriteReference{#1}{\rev@ReferenceId}%
  \begin{Quote}{\rev@CommentIdBox{\rev@ReferenceId} [\rev@LocationText{#1}]}%
    % The quoted text is a copy of the paper's, so any \label in it would
    % clash with the same label imported from the paper by xr.  Suppress
    % it here (\ref/\pageref still resolve through the imported labels).
    \let\label\@gobble%
    \Paste{#1}%
  \end{Quote}%
}
\def\CopyQuotation#1{\RQuote{#1}}

% copy-and-paste feature
\long\def\RCopy#1#2{%
  % \long: the stored text may contain \par; \gdef: the definition must
  % survive the end of a surrounding group/environment
  \expandafter\long\expandafter\gdef\csname rev@clipboard@#1\endcsname{#2}%
  #2%
}
% The text was already typeset (with its \label) by \RCopy, so suppress
% \label here to avoid defining the same label twice in one document.
\def\RPaste#1{{\let\label\@gobble\csname rev@clipboard@#1\endcsname}}



%%% Comment and Reply feature

% comment/reference counter
\newcounter{RevComment}
\setcounter{RevComment}{0}
\newcounter{RevReference}
\setcounter{RevReference}{0}

% reviewer id
\xdef\rev@ReviewerId{0}
\def\Reviewer#1{%
  \xdef\rev@ReviewerId{#1}%
  \setcounter{RevComment}{0}%
}

% comment id
\def\rev@CommentId{}
\def\rev@GenerateCommentId#1{%
  \ifx*#1% default
    \addtocounter{RevComment}{1}%
    \xdef\rev@CommentId{\rev@ReviewerId.\arabic{RevComment}}%
  \else%
    \xdef\rev@CommentId{\rev@ReviewerId.#1}%
  \fi%
  \setcounter{RevReference}{0}%
}

% reference id
\def\rev@ReferenceId{}
\def\rev@GenerateReferenceId{%
  \addtocounter{RevReference}{1}%
  \xdef\rev@ReferenceId{\rev@CommentId\alphalph{\value{RevReference}}}%
}

% comment
\newcommand{\Comment}[1][*]{%
  % id generation
  \rev@GenerateCommentId{#1}%
  % hr
  \rev@HorizontalLine
  \vspace{0em}
  
  \noindent
  \rev@CommentBox{gray}{\rev@CommentText{\rev@CommentId}}\xspace%
  \begingroup
  \itshape % start italic
  \small
  \color{gray}
}
\newcommand{\Reply}{%
  \endgroup % end italic
  ~ \\
  \rev@CommentBox{black}{\rev@AnswerText{\rev@CommentId}}\xspace%
}

% quote
\newenvironment{Quote}[1]%
  {\vspace{1em}\small\begin{quote}#1\\}%
  {\end{quote}}

% author note
\def\Note#1#2{{\footnotesize\begin{quote}[** #1] #2\end{quote}}}

\DeclareOption{paper}{%
  \def\Label#1{\rev@MarginPar{\rev@CommentIdContent{#1}}}
  \long\def\Revised#1#2{%
    \Label{#1}%
    \rev@WriteRevision{#1}{#2}%
  }
  \long\def\RevisedNoMark#1#2{\rev@WriteRevision{#1}{#2}}
  \long\def\Modified#1{\rev@HighlightedText{#1}}
  \long\def\Deleted#1{\rev@StrikedText{#1}}
}
\DeclareOption{cameraready}{%
  \def\Label#1{}
  \long\def\Revised#1#2{#2}
  \long\def\RevisedNoMark#1#2{#2}
  \long\def\Modified#1{#1}
  \long\def\Deleted#1{}
}
\DeclareOption{letter}{%
  % defines the same command set as the paper/cameraready options so that
  % \D, \Rep, \Replaced, etc. also work inside the letter
  \def\Label#1{}
  \long\def\Revised#1#2{#2}
  \long\def\RevisedNoMark#1#2{#2}
  \long\def\Modified#1{\rev@HighlightedText{#1}}
  \long\def\Deleted#1{\rev@StrikedText{#1}}
}

% Japanese: strike out with uline--, which breaks lines in both scripts
% (\mline's own color= option only reaches some of the lines, so the color
% is applied from the outside, exactly as with \sout), and translate the
% literals.  Orthogonal to paper/letter/cameraready: [paper,ja]
\DeclareOption{ja}{%
  \rev@jatrue
  \long\gdef\rev@StrikedText#1{{\color{red}\mline{#1}}}%
  \gdef\rev@CommentText#1{コメント#1}%
  \gdef\rev@AnswerText#1{#1への回答}%
  \gdef\rev@PageText#1{#1ページ}%
  \gdef\rev@AbstractText{概要}%
  \gdef\rev@SectionText#1{#1節}%
}

\ExecuteOptions{paper}
\ProcessOptions

% Forgetting 'ja' leaves \Deleted unable to break lines, which is easy to
% miss among the overfull warnings it causes.  \kanjiskip exists in the
% pTeX family (and in LuaTeX-ja, where lua-ul would be the answer instead).
\@ifundefined{kanjiskip}{}{%
  \ifrev@ja\else
    \PackageWarning{revision}{Japanese engine detected without the 'ja'
      option; struck-out Japanese text will not break across lines}%
  \fi
}
