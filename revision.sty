% -*- latex -*-
\NeedsTeXFormat{pLaTeX2e}[2001/09/04]
\ProvidesPackage{revision}[2010/09/16, hayashi]

% usage:
% \usepackage[paper]{revision},
% \usepackage[cr]{revision}, or
% \usepackage[letter]{revision}



\DeclareOption{en}{%
  \gdef\r@SecNameGen#1{Section~#1}
  \gdef\r@AbstractName{Abstract}
  \gdef\r@CommentName{Comment~}
  \gdef\r@ConditionName{Condition~}
}
\DeclareOption{ja}{%
  \gdef\r@SecNameGen#1{{#1}$B@a(B}
  \gdef\r@AbstractName{$B35MW(B}
  \gdef\r@CommentName{$B%3%a%s%H(B}
  \gdef\r@ConditionName{$B:NO?>r7o(B}
}

\DeclareOption{paper}{%
  \AtEndOfPackage{
    \RequirePackage[dvips]{color}
    \RequirePackage{xr}
    \RequirePackage[normalem]{ulem}
  }
  \def\IfRevision#1{#1}

  \def\Modified#1{{\color{red}#1}}
  %\def\Removed#1{}
  \def\Removed#1{\Modified{\sout{#1}}}
  \def\Replaced#1#2{\Removed{#1}\Modified{#2}}

  %\def\revB#1{{\color{blue}#1}}
  %\def\rev#1{{\color[named]{Purple}#1}}
  %\def\revC#1{{\color[named]{OliveGreen}#1}}

  % section number
  % BUGGY??
  \def\r@SecNumber{%
    \ifnum\c@section>0%
      \ifnum\c@subsection>0%
        \ifnum\c@subsubsection>0%
          \thesubsubsection%
        \else%
          \thesubsection%
        \fi%
      \else%
        \thesection%
      \fi%
    \else%
      %
    \fi%
  }

  % section name (Section 1.1, etc.)
  \def\r@SecName{%
    \ifnum\c@section>0%
      \ifnum\c@subsection>0%
        \ifnum\c@subsubsection>0%
          \r@SecNameGen{\thesubsubsection}%
        \else%
          \r@SecNameGen{\thesubsection}%
        \fi%
      \else%
        \r@SecNameGen{\thesection}%
      \fi%
    \else%
      \r@AbstractName%
    \fi%
  }

  % floating comment
  \def\r@marginparL#1{\marginpar{\begin{flushright}#1\end{flushright}}}
  \def\r@marginparR#1{\marginpar{#1}}
  \def\r@marginparLR#1{\if@firstcolumn\r@marginparL{#1}\else\r@marginparR{#1}\fi}
  \def\r@marginparBoth#1{\marginpar{%
    \begin{minipage}{0.5\hsize}\begin{flushleft}#1\end{flushleft}\end{minipage}%
    \begin{minipage}{0.495\hsize}\begin{flushright}#1\end{flushright}\end{minipage}%
  }}
  \def\ShowCommentId#1{\r@marginparBoth{{\small\color{black}\fbox{\pageref{comment:#1}}}}}
%  \def\ShowCommentId#1{\r@marginparR{{\color{black}\fbox{\pageref{comment:#1}}}}}

  \long\def\WriteRevision#1#2#3{%
    \@temptokena{#3}%
    \immediate\write\@auxout{\string\newlabel{#1}{{#2}{\the\@temptokena}}}
  }

  \long\def\Revised#1#2{% #1:key, #2:contents
    \WriteRevision{revised:#1}{\r@SecName}{#2}%
    \ShowCommentId{#1}%
    {#2}%
  }
}

\DeclareOption{cameraready}{%
  \def\IfRevision#1{}
  \long\def\Revised#1#2{#2}
  \def\Modified#1{#1}
  \def\Removed#1{}
}

\DeclareOption{letter}{%
  \AtEndOfPackage{
    \RequirePackage[dvips]{color}
    \RequirePackage{okumacro}
    \RequirePackage{xr}
    \RequirePackage[normalem]{ulem}

    % http://newsgroups.derkeiler.com/Archive/Comp/comp.text.tex/2009-05/msg00262.html
    % \cite on xr
    \long\def\XR@test#1#2#3#4\XR@{%
      \ifx#1\newlabel
        \newlabel{\XR@prefix#2}{#3}%
      \else%
        \ifx#1\@input
          \edef\XR@list{\XR@list#2\relax}%
        \fi%
      \fi
      \ifx\bibcite#1\relax
        \bibcite{\XR@prefix#2}{#3}%
      \fi
      \ifeof\@inputcheck\expandafter\XR@aux
      \else\expandafter\XR@read\fi%
    }
  }

  \long\def\Revised#1#2{#2}
  \def\Modified#1{{\color{red}#1}}
  \def\Removed#1{\Modified{\sout{#1}}}

  % comment counter
  \xdef\r@CommentCounter{}
  \newcounter{comment}
  \setcounter{comment}{0}

  % reviewer id
  \xdef\r@ReviewerId{0}
  \def\Reviewer#1{%
    \xdef\r@ReviewerId{#1}%
    \setcounter{comment}{0}%
    \clearpage%
  }

  % comment id
  \def\r@CommentId{}
  \def\r@GenerateCommentId#1{
    \addtocounter{comment}{1}%
    \ifx-#1%
       \xdef\r@CommentId{{\r@ReviewerId}-{\arabic{comment}}}
    \else%
       \xdef\r@CommentId{{\r@ReviewerId}-{#1}}
    \fi%
  }

  % comment
  \newenvironment{COMMENT}[1][-]%
    {~\\
     \r@GenerateCommentId{#1}
     \small
     \begin{screen}{\bf \r@CommentName\r@CommentId:}\\}%
    {\end{screen}}
  % \Alph{com} : A, B, C...

  % condition
  \newenvironment{CONDITION}[1][-]%
    {~\\
     \r@GenerateCommentId{#1}
     \small
     \begin{screen}{\bf \r@ConditionName\r@CommentId:}\\}%
    {\end{screen}}
  % \Alph{com} : A, B, C...

  \newenvironment{QUOTE}[1]%
    {\vspace{1em}\small\begin{quote} [#1]\\}%
    {\end{quote}}

  \def\CPQUOTE#1{%
    % write relationship
    \immediate\write\@auxout{\string\newlabel{comment:#1}{{}{\r@CommentId}}}%
    \begin{QUOTE}{\ref{revised:#1}}%
      \pageref{revised:#1}%
    \end{QUOTE}%
  }

  \def\NOTE#1#2{%
    {\footnotesize \begin{quote}%
      [$B!z(B #1] #2
    \end{quote}}
  }
}

\ExecuteOptions{paper}
\ProcessOptions
